hosts:
  # 示例服务器配置
  # 请复制此文件为 hosts.yaml，并填入真实的服务器信息
  example-server:
    deploy_dir: /opt/app          # 部署到目标服务器的目录
    host: 192.168.1.100          # 服务器 IP 地址
    port: 22                      # SSH 端口
    username: root                # SSH 用户名
    password: your_password_here    # SSH 密码（或使用 ssh_key）
    # ssh_key: ~/.ssh/id_rsa      # SSH 密钥路径（可选，优先于密码）
    # owner: admin                 # 部署所有者标识（可选）

  # 支持多个服务器配置
  # another-server:
  #   deploy_dir: /opt/app
  #   host: 192.168.1.101
  #   port: 22
  #   username: ubuntu
  #   ssh_key: ~/.ssh/id_rsa
